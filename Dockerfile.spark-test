# Spark 3.x + opensearch-hadoop connector (이슈 #711 테스트)
# Bitnami는 Docker Hub에 태그를 더 이상 제공하지 않으므로 ECR 공개 이미지 사용
FROM public.ecr.aws/bitnami/spark:3.4.1

USER root

# ---------- Official 전용: Maven에서 JAR 다운로드 ----------
ARG OPENSEARCH_HADOOP_VERSION=1.0.1
ARG CONNECTOR_JAR=opensearch-spark-30_2.12-${OPENSEARCH_HADOOP_VERSION}.jar
ARG MAVEN_URL="https://repo1.maven.org/maven2/org/opensearch/client/opensearch-spark-30_2.12/${OPENSEARCH_HADOOP_VERSION}/${CONNECTOR_JAR}"

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/connectors \
    && curl -sL -o "/opt/connectors/${CONNECTOR_JAR}" "${MAVEN_URL}"

ENV SPARK_OPENSEARCH_JAR="/opt/connectors/${CONNECTOR_JAR}"
# ---------------------------------------------------------------------

WORKDIR /app
COPY scripts/spark_read_test.py /app/
COPY scripts/setup_index.sh /app/scripts/
COPY scripts/verify_opensearch.sh /app/scripts/
RUN chmod +x /app/scripts/*.sh

# Hadoop Kerberos 비활성화용 설정 (simple 인증)
COPY conf/hadoop /app/hadoop-conf

COPY run_test.sh /app/
RUN chmod +x /app/run_test.sh

# USER 1001 이 JAR, /app, hadoop-conf 읽을 수 있도록 권한 부여
RUN chown -R 1001:root /opt/connectors /app

# Bitnami Spark 이슈: UID 1001이 /etc/passwd에 없으면 UnixLoginModule이 "invalid null input: name" 발생
# → KerberosAuthException 방지를 위해 spark 사용자(UID 1001) 등록
RUN if ! getent passwd 1001 >/dev/null 2>&1; then \
      echo 'spark:x:1001:1001:Spark User:/app:/bin/bash' >> /etc/passwd; \
      echo 'spark:x:1001:' >> /etc/group; \
    fi

# Ivy 경로 오류 방지: basedir must be absolute (HOME 미설정 시 ?/.ivy2/local 로 해석됨)
ENV HOME=/app

USER 1001
ENTRYPOINT ["/app/run_test.sh"]
